# services/data 服务的环境变量
# 拷贝到 services/data/.env 并填实值

# === 基础（来自 inalpha-shared.Settings） ===

DATABASE_URL=postgresql+psycopg://quant:devpass@localhost:5433/inalpha
JWT_SECRET=replace-with-32-byte-shared-secret-across-services

# JWT_ALGORITHM=HS256          # 默认 HS256
# SERVICE_NAME=data            # 默认 data（DataSettings 覆盖）
# LOG_LEVEL=INFO

# === Binance（K线 / OHLCV 是公开接口，可以不填；私有接口才需要） ===

BINANCE_API_KEY=
BINANCE_API_SECRET=

# === Service ===

DATA_SERVICE_PORT=8001
