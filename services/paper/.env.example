# services/paper 服务的环境变量
# 拷贝到 services/paper/.env 并填实值

# === 基础（来自 inalpha-shared.Settings） ===

# paper 服务本身不直接连 DB（D-6 不持久化 backtest_runs），但 _shared
# 的 Settings 要求 DATABASE_URL，保留以便 D-7 起持久化时无需改 schema
DATABASE_URL=postgresql+psycopg://quant:devpass@localhost:5433/inalpha
JWT_SECRET=replace-with-32-byte-shared-secret-across-services
# JWT_ALGORITHM=HS256
# SERVICE_NAME=paper
# LOG_LEVEL=INFO

# === 跨服务调用 ===

# data-service 地址（paper 拉历史 K 线时调）
DATA_SERVICE_URL=http://localhost:8001

# === Service ===

PAPER_SERVICE_PORT=8002

# === D-9 RiskEngine HTTP 接入（ADR-0006 / issue #3） ===

# false 时 HTTP 下单链路（/orders/submit + /plans/{id}/execute）跳过风控拦截。
# 默认 true；运维窗口期 / 数据迁移可临时关。
# INALPHA_RISK_ENGINE_ENABLED=true

# risk_rules.toml 路径（相对工作目录或绝对路径）。
# 默认 configs/risk_rules.toml；缺失 / 解析失败时 fail-open 不阻塞服务起步。
# INALPHA_RISK_RULES_CONFIG=configs/risk_rules.toml

# Demo / single-account 模式（仅供 issue #3 演示，production 多账户走 issue #8）：
# 设置后 lifespan 用 PostgresTradeRepository 替换 _NoopTradeRepo，
# 让 trade-based RiskRule (Cooldown / StoplossGuard / LowProfit / MaxDrawdown) 真触发。
# 需要先用 scripts/demo_risk_seed.py 往 closed_trades 表注入数据。
# INALPHA_RISK_DEMO_ACCOUNT_SUB=service:orchestration
