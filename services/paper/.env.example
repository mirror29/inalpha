# services/paper 服务的环境变量
# 拷贝到 services/paper/.env 并填实值

# === 基础（来自 inalpha-shared.Settings） ===

# paper 服务本身不直接连 DB（D-6 不持久化 backtest_runs），但 _shared
# 的 Settings 要求 DATABASE_URL，保留以便 D-7 起持久化时无需改 schema
DATABASE_URL=postgresql+psycopg://quant:devpass@localhost:5433/inalpha
JWT_SECRET=replace-with-32-byte-shared-secret-across-services
# JWT_ALGORITHM=HS256
# SERVICE_NAME=paper
# LOG_LEVEL=INFO

# === 跨服务调用 ===

# data-service 地址（paper 拉历史 K 线时调）
DATA_SERVICE_URL=http://localhost:8001

# === Service ===

PAPER_SERVICE_PORT=8002
