# ============================================================
# Inalpha · 统一环境配置（单 .env，全 service 共享）
# ============================================================
# 拷贝本文件为根目录的 .env 后填值：
#
#     cp .env.example .env
#
# 加载顺序：
# 1) `scripts/dev.sh` 启动前 source 根 `.env` → 子进程继承
# 2) 各 service 代码层 fallback：Python pydantic-settings 显式读
#    `<repo-root>/.env`；TS Mastra 用 `dotenv` 同样指向根。
# 3) 旧 `services/*/.env` / `packages/orchestration/.env` 仍作为
#    cwd-level fallback **覆盖**根 .env（迁移期友好；迁移完可删）。
#
# 字段按 service 分组，但全部住在这一个文件里。
# ============================================================


# ───── 1. 共享基础（所有 Python service 都读） ──────────────
# Postgres 连接串；services/data 与 services/paper 使用
DATABASE_URL=postgresql+psycopg://quant:devpass@localhost:5433/inalpha

# JWT 跨 service 共享密钥（≥32 字节强随机）
JWT_SECRET=please-change-me-32-chars-minimum-xxxx
JWT_ALGORITHM=HS256
LOG_LEVEL=INFO

# 多用户登录开关:dashboard 读。false/不设(本地)=不登录回落 CONSOLE_SUBJECT;
# true(线上)=强制登录。账号存 DB(users 表),用 services/paper/scripts/create_user.py 种入。
AUTH_ENABLED=false


# ───── 2. Service URLs & ports（本地默认） ─────────────────
DATA_SERVICE_URL=http://localhost:8001
PAPER_SERVICE_URL=http://localhost:8002
RESEARCH_SERVICE_URL=http://localhost:8003
FACTOR_SERVICE_URL=http://localhost:8004

DATA_SERVICE_PORT=8001
PAPER_SERVICE_PORT=8002
RESEARCH_SERVICE_PORT=8003
FACTOR_SERVICE_PORT=8004

# factor 服务可选项（ADR-0043）：qlib Alpha158 风格因子纯 pandas 本地算，默认开；
# 设 false 可整源关闭。snapshot top-N 去相关阈值默认 0.85（1.0 = 关闭去相关）
# FACTOR_QLIB_ENABLED=true
# FACTOR_SNAPSHOT_CORR_THRESHOLD=0.85
# 因子面板缓存 TTL（秒，只缓存 live 调用，实际=min(此值,半根 bar)，0=关）
# FACTOR_CACHE_TTL_S=300
# FRED 宏观因子源（ADR-0044，仅 1d/1wk timeframe；需 data 服务配 FRED key，缺 key 自动降级）
# FACTOR_MACRO_ENABLED=true


# ───── 3. LLM Provider（必填一个 API key） ─────────────────
# 选 provider：deepseek | anthropic | openai | gemini | kimi | zhipu | ollama
LLM_PROVIDER=deepseek

# 留空 = 各 provider 默认主流旗舰（2026-05 更新）。要换模型时填具体 ID，例如：
#   deepseek  → deepseek-v4-pro (旗舰) / deepseek-v4-flash (快速) /
#               deepseek-chat (老 alias，2026-07-24 下线) / deepseek-reasoner (推理)
#   anthropic → claude-opus-4-8 (旗舰) / claude-sonnet-4-6 (省) / claude-haiku-4-5 (最便宜)
#   openai    → gpt-5.5 (旗舰) / gpt-5.4-mini / gpt-5.4-nano (快) /
#               gpt-5.2-pro (推理) / gpt-5.2-chat-latest (instant)
#   gemini    → gemini-3-pro (旗舰，替代 2.5-pro) / gemini-3.5-flash (GA 快) /
#               gemini-3.1-pro-preview (preview)
#   kimi      → kimi-k2.6 (最新旗舰) / kimi-k2-0905 (2026-05-25 下线，迁移 k2.6)
#   zhipu     → glm-5.2 (旗舰) / glm-5 / glm-5-turbo / glm-4.5-air (轻量)
#   ollama    → llama4 (Scout 默认) / llama4:128x17b (Maverick，要大显存) /
#               llama3.3 / qwen3 / 任何已 `ollama pull` 的本地模型
LLM_MODEL=

# 各 provider 的 API key（只需填你 LLM_PROVIDER 选中的那家）
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
ZHIPU_API_KEY=

# Ollama 本地不需要 key，配 base URL 即可（默认 http://localhost:11434/v1）
OLLAMA_BASE_URL=http://localhost:11434/v1

# LLM 护栏（可选，有默认值）
LLM_TIMEOUT_SECONDS=60
LLM_MAX_CONCURRENT=5
LLM_MAX_RETRIES=3
# Bull/Bear 辩论轮数（services/research）；0 = 跳过
RESEARCH_MAX_DEBATE_ROUNDS=1


# ───── 4. services/data · Binance ──────────────────────────
# K 线 / OHLCV 公开接口可空；私有接口才填
BINANCE_API_KEY=
BINANCE_API_SECRET=

# FRED 宏观数据（venue=fred）——factor service 的宏观因子（macro.*）依赖它。
# 免费、秒发：https://fred.stlouisfed.org/docs/api/api_key.html
# 留空 = connector 不注册，venue=fred 不可用，宏观因子优雅降级（价量因子不受影响）。
# 注意：宏观因子仅在 timeframe=1d/1wk 计算（月频数据在 intraday bar 上是阶梯函数，刻意不出）。
FRED_API_KEY=

# 指数成分每日快照调度（PIT 向前累积）——横截面轮动/选股回测去存活者偏差用。
# 给调度器一份「每天去给哪些指数拍成分快照」的点名册：逗号分隔指数代码，留空=禁用调度
# （后台循环不起，constituent_snapshot 表保持空，panel_score 传 index_code 一律走 non-PIT 降级）。
#
# 为什么要它：akshare 只回**当前**成分、免费历史拿不到 → 唯一 PIT 路径是从启用日起每日把
# 当前成分落库、向前累积。**覆盖从配置那天起向前增长，不回填历史，越早配可用于无偏回测的历史越长。**
#
# 目前 connector 走 akshare 中证接口，只支持 **A股指数代码**（美股/港股成分快照需另接数据源，未做）：
#   000300 沪深300 / 000905 中证500 / 000016 上证50 / 000852 中证1000 / 399006 创业板指
# 不预设市场：按你实际要回测的指数填，别贪多（akshare 是爬虫接口，抓越多越易被封）。
# 手动 POST /constituents/snapshot 不受本项影响（仍可随时按需落一份）。
CONSTITUENT_SNAPSHOT_INDICES=
# 调度检查间隔（小时，默认 12）。幂等：每轮只补「今天还没快照」的指数，<24h 不会重复打源站；
# >1 轮/天纯为重启后尽快补当天（uvicorn --reload 频繁重启场景）。
# CONSTITUENT_SNAPSHOT_INTERVAL_H=12


# ───── 5. services/paper · RiskEngine（可选） ──────────────
# false = HTTP 下单链路跳过风控（运维窗口 / 数据迁移可临时关，默认 true）
# INALPHA_RISK_ENGINE_ENABLED=true
# risk_rules.toml 路径（默认 configs/risk_rules.toml）
# INALPHA_RISK_RULES_CONFIG=configs/risk_rules.toml


# ───── 6. orchestration / Mastra（可选） ──────────────────
# 类 cron agent 模式；默认 false
SCHEDULER_ENABLED=false
