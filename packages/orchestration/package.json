{
  "name": "@inalpha/orchestration",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Mastra 编排层：tool / agent / workflow / memory，把后端 service 暴露给 LLM",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools/index.ts",
    "./clients": "./src/clients/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'TODO: add eslint or biome'",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:plan": "tsx scripts/smoke-plan.ts",
    "dev": "mastra dev --dir src/mastra"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@mastra/core": "^1.36.0",
    "@mastra/libsql": "^1.11.1",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.19.0",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "mastra": "^1.10.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
