{
  "name": "@inalpha/orchestration",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Mastra 编排层：tool / agent / workflow / memory，把后端 service 暴露给 LLM",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools/index.ts",
    "./clients": "./src/clients/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'TODO: add eslint or biome'",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:plan": "tsx scripts/smoke-plan.ts",
    "scheduler:trigger": "tsx scripts/scheduler-trigger.ts",
    "smoke:sandbox": "tsx scripts/smoke-sandbox.ts",
    "smoke:sandbox-loop": "tsx scripts/smoke-sandbox-loop.ts",
    "smoke:coingecko": "tsx scripts/smoke-coingecko-mcp.ts",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "dev": "mastra dev --dir src/mastra"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.35",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^2.0.35",
    "@ai-sdk/openai": "^2.0.35",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@mastra/core": "^1.36.0",
    "@mastra/libsql": "^1.11.1",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.19.0",
    "@mastra/observability": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "croner": "^9.0.0",
    "dotenv": "^17.2.3",
    "hono": "^4.12.21",
    "jose": "^6.2.3",
    "pg": "^8.13.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.10",
    "mastra": "^1.10.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
