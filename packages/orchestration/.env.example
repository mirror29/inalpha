# packages/orchestration 的环境变量
# 拷贝到 packages/orchestration/.env

# === 跨服务调用 ===

DATA_SERVICE_URL=http://localhost:8001
PAPER_SERVICE_URL=http://localhost:8002

# === Auth ===

# JWT_SECRET 必须和 services/*/JWT_SECRET 完全一致（同一密钥跨服务共享）
JWT_SECRET=replace-with-32-byte-shared-secret-across-services
# JWT_ALGORITHM=HS256

# === LLM Provider（D-8 起接入 LLM agent 时才用，D-7 不用） ===

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
