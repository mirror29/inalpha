# Inalpha 生产环境变量参考 —— 复制为 infra/.env.prod 并填值
# 见 docs/miro/decisions/0042-backend-hosting-deployment.md
#
# 安全红线：
#   - 不要把 .env.prod 入 git（应已在 .gitignore；若否请加）
#   - 不要带任何 *_PROXY（本地代理拦 localhost 那套在云上会把 httpx 打挂）
#   - secret 优先走平台 secret 管理，文件仅作单机起步

# ---- Postgres ----
POSTGRES_USER=quant
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=inalpha
# 容器内服务用此 URL（服务名 postgres）；alembic / 各服务读
DATABASE_URL=postgresql://quant:__CHANGE_ME__@postgres:5432/inalpha

# ---- Redis（如服务用到）----
REDIS_URL=redis://redis:6379/0

# ---- 服务间地址（容器名互访；mastra 另在 compose 内覆盖）----
DATA_SERVICE_URL=http://data:8001
PAPER_SERVICE_URL=http://paper:8002
RESEARCH_SERVICE_URL=http://research:8003
FACTOR_SERVICE_URL=http://factor:8004
MASTRA_URL=http://mastra:4111

# ---- 鉴权（dashboard BFF ↔ 后端）----
JWT_SECRET=__CHANGE_ME__
JWT_ALGORITHM=HS256
CONSOLE_SUBJECT=console:dev

# ---- LLM 提供商 key（按实际用到的填；root .env 曾缺 DEEPSEEK 导致 500）----
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- 行情数据源 ----
BINANCE_API_KEY=
BINANCE_API_SECRET=
# 其它 venue / FRED 等按需补

# ---- live runner ----
# paper 启动时是否自动 resume 之前 running 的策略
LIVE_RUNNER_RESUME_ON_STARTUP=true

# ---- Cloudflare Tunnel（公网入口）----
CLOUDFLARE_TUNNEL_TOKEN=
