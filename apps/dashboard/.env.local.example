# Inalpha 操作者控制台 · 本地环境
# 复制为 .env.local 后按需改值。控制台是开发/操作者工具,单用户、dev token。

# ── 后端 service 地址(BFF 在 server 侧转发,浏览器不直连)──
PAPER_SERVICE_URL=http://127.0.0.1:8002
DATA_SERVICE_URL=http://127.0.0.1:8001
RESEARCH_SERVICE_URL=http://127.0.0.1:8003
MASTRA_URL=http://127.0.0.1:4111

# ── 鉴权 ──
# 必须与后端(根 .env)的 JWT_SECRET 一致,否则后端验签失败 401。
# 后端只接受对称算法(HS256/384/512)。
JWT_SECRET=
JWT_ALGORITHM=HS256

# 控制台登录身份:后端按 sub 派生稳定 account_id(见 services/paper/.../account_id.py)。
# 改这个 sub 等于切换到另一个账户的视图。
CONSOLE_SUBJECT=console:dev
CONSOLE_EMAIL=console@inalpha.dev
